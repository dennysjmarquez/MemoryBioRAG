# =============================================================================
# BioRAG v8.0 — Configuración de Usuario
# =============================================================================
# Copia este archivo a .env.local y descomenta los valores que quieras cambiar.
# Los defaults están en el código — este archivo es SOLO para override.
# Si eliminas este archivo o las variables, el código usa los defaults.
# =============================================================================

# =============================================================================
# 1. BASE DE DATOS
# =============================================================================
# Ruta al archivo .db donde BioRAG guarda toda la memoria.
# Default: ./MemoryBioRAG_Data/memory_biorag.db
# Ejemplo: si quieres otra ubicación o nombre de archivo
# BIORAG_PATH=/home/usuario/mi_biorag/memoria.db

# =============================================================================
# 2. LÍMITE DE RESULTADOS (Límite por defecto en búsquedas MCP)
# =============================================================================
# Cuántos resultados retorna cada búsqueda por defecto.
# Default: 10
# Más resultados = más información, pero más tokens en el contexto del LLM.
# Ejemplo: poner 5 si solo quieres los top 5 más relevantes
# BIORAG_LIMITE_MCP=10

# =============================================================================
# 3. CANDIDATOS PARA SIMILITUD CONCEPTUAL
# =============================================================================
# Cuántos nodos candidatos se evalúan para calcular similitud conceptual (Jaccard).
# Default: 100
# Más candidatos = más preciso pero más lento.
# Si tu DB tiene pocos nodos (<100), puedes bajarlo a 50.
# Si tu DB tiene muchos nodos (>500), sube a 200.
# Ejemplo: BIORAG_CANDIDATOS_SIMILITUD=100

# =============================================================================
# 4. MÁXIMO DE SALTOS EN EVOCACIÓN POR CADENA
# =============================================================================
# Cuántos "hops" de conexión hace el sistema cuando sigue un camino de sinapsis.
# Default: 3
# Cada salto aplica un decay logarítmico (score = 1/(2^salto)):
#   - Salto 1: score 0.50 (conexión directa)
#   - Salto 2: score 0.25 (conexión del vecino)
#   - Salto 3: score 0.125 (conexión del vecino del vecino)
# Más saltos = más resultados pero menos relevantes.
# Ejemplo: BIORAG_MAX_SALTOS_CADENA=3

# =============================================================================
# 5. LÍMITE DE RESULTADOS POR CAPA DE BÚSQUEDA
# =============================================================================
# Cuántos resultados máximo saca cada capa del pipeline (FTS5, OR, semántica, etc.)
# Default: 5
# Afecta a: buscar_por_frase, buscar_por_rafaga, evocación por cadena.
# Ejemplo: BIORAG_LIMITE_DEFAULT=5

# =============================================================================
# 6. UMBRAL JACCARD PARA SIMILITUD CONCEPTUAL
# =============================================================================
# Score mínimo de Jaccard para considerar que dos nodos son conceptualmente similares.
# Default: 0.15
# Rango: 0.0 (acepta todo) a 1.0 (solo idénticos).
# Más alto = menos resultados pero más precisos.
# Más bajo = más resultados pero puede incluir ruido.
# Ejemplo: BIORAG_UMBRAL_JACCARD=0.15

# =============================================================================
# 7. LÍMITE EN SIMILITUD CONCEPTUAL
# =============================================================================
# Cuántos resultados retorna la capa de similitud conceptual latente.
# Default: 5
# Ejemplo: BIORAG_LIMITE_SIMILITUD=5

# =============================================================================
# 8. LÍMITE EN BÚSQUEDA POR RÁFAGA
# =============================================================================
# Cuántos resultados retorna cada palabra de la ráfaga de reminiscencia.
# Default: 5
# Ejemplo: BIORAG_LIMITE_RAFTAGA=5

# =============================================================================
# 9. LÍMITE EN EVOCACIÓN POR CADENA
# =============================================================================
# Cuántos resultados totales permite la evocación por cadena (multi-hop).
# Default: 5
# Ejemplo: BIORAG_LIMITE_EVOCACION=5

# =============================================================================
# 10. RÁFAGA DE REMINISCENCIA (ON/OFF)
# =============================================================================
# Activa o desactiva completamente la ráfaga de reminiscencia.
# Default: true (activada)
# La ráfaga es la funcionalidad más poderosa de BioRAG: cuando FTS5 falla
# o el score es bajo, el LLM genera 10-15 palabras relacionadas y el script
# busca con cada una para encontrar recuerdos dormidos o aislados.
# Desactivar solo si tienes una razón específica (ej: benchmark puro).
# Ejemplo: BIORAG_RAFTAGA_ACTIVA=true

# =============================================================================
# 11. THRESHOLD PARA ACTIVAR RÁFAGA AUTOMÁTICAMENTE
# =============================================================================
# Score mínimo del top resultado para activar la ráfaga automáticamente.
# Default: 0.5
# Si el mejor resultado tiene score < 0.5, la ráfaga se activa automáticamente.
# Si es >= 0.5, se asume que los resultados son suficientemente buenos.
# Ejemplo: poner 0.3 si solo quieres ráfaga con scores muy bajos.
# Ejemplo: poner 0.7 si quieres que la ráfaga se active más frecuentemente.
# BIORAG_THRESHOLD_RAFTAGA=0.5

# =============================================================================
# NOTAS:
# - Los valores aquí son OPCIONALES. Si no pones nada, se usan los defaults.
# - Los defaults están en el código de memory_store.py y mcp_server.py.
# - .env.local tiene prioridad sobre .env.example (gitignore lo excluye).
# - Para probar: export BIORAG_LIMITE_MCP=5 && python3 mcp_server.py
# =============================================================================
